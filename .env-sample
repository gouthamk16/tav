# OpenAI embeddings (required only when --embed_model openai)
OPENAI_API_KEY=your_openai_api_key

# Optional default backend URI (used when --store_uri is not provided)
# PostgreSQL example: postgresql://user:pass@localhost:5432/tav
# MongoDB example: mongodb://localhost:27017
TAV_STORE_URI=

# Optional S3 ingest default path (used when --s3_path is not provided)
TAV_S3_PATH=s3://your-bucket/your-prefix/

# AWS config for S3 access
AWS_REGION=us-east-1
AWS_PROFILE=default

# Optional for S3-compatible providers (MinIO, LocalStack, etc.)
AWS_ENDPOINT_URL_S3=

# Optional explicit credentials (if you are not using profile-based auth)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
